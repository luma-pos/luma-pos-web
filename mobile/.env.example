# Cùng project Supabase với web (giá trị = NEXT_PUBLIC_SUPABASE_URL / ANON_KEY của web).
# Copy file này thành .env rồi điền giá trị thật. Expo chỉ đọc biến có tiền tố EXPO_PUBLIC_.
EXPO_PUBLIC_SUPABASE_URL=https://tjodugffqvihqwczqsjz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY

# URL app web (Next.js) — nơi có API tạo đơn /api/pos/order.
# Production: domain Vercel. Dev cùng máy: http://<IP-LAN-máy-tính>:3000 (KHÔNG dùng localhost).
EXPO_PUBLIC_API_URL=https://your-web-domain.vercel.app
